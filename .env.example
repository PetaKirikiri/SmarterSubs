# Supabase Configuration Template
# Copy this file to .env and fill in your actual values
# Get credentials from: Supabase Dashboard → Settings → API

# Supabase Project URL
VITE_SUPABASE_URL=https://gbsopnbovsxlstnmaaga.supabase.co

# Supabase Anonymous/Public Key (starts with 'eyJ...')
# Get from: Settings → API → anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (for schema inspection - has elevated permissions)
# Get from: Settings → API → service_role key (⚠️ Keep secret!)
# This can be used instead of DATABASE_URL password for schema inspection
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Personal Access Token (starts with sbp_…) — Dashboard → Account → Access Tokens.
# Optional: `npm run sync:pipeline-preview-edge-secrets` pushes API keys below to Edge secrets.
# SUPABASE_ACCESS_TOKEN=sbp_your_pat_here

# PostgreSQL Connection String (for setup:replace-rpc, Drizzle introspection)
# Get from: Settings → Database → Connection string
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Alternative: set SUPABASE_DB_PASSWORD (script builds URL from VITE_SUPABASE_URL)
DATABASE_URL=postgresql://postgres:your-password-here@db.gbsopnbovsxlstnmaaga.supabase.co:5432/postgres

# OpenAI API Key (optional - for GPT normalization feature)
# Get from: https://platform.openai.com/api-keys
# Can also be set in browser localStorage as 'smartSubs_openaiApiKey'
# VITE_OPENAI_API_KEY=sk-...

# AI4Thai API Key (optional - for tokenization and G2P processing)
# Get from: https://aiforthai.in.th/
# Can also be set in browser localStorage as 'smartSubs_ai4thai_apiKey'
# Required for: Thai tokenization (LexTo+, TLex+), spell checker, Xiaofan Thai→English MT, G2P (grapheme-to-phoneme) conversion
# VITE_AI4THAI_API_KEY=your-ai4thai-api-key-here
# LexTo+ norm: 0 = default (no API normalize), 1 = collapse repeated chars (e.g. มากกก → มาก)
# VITE_AI4THAI_LEXTO_NORM=0

# ─── Cloudflare R2 (TTS / audio files) ───
# Edge function upload-r2-audio reads these from Supabase Edge secrets, not from this file.
# After filling the lines below in .env, run: ./scripts/sync-r2-edge-secrets.sh (needs supabase login)
# Same layout as Pūrākau: see docs/cloudflare-r2-credentials.md
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_S3_ACCESS_KEY_ID=
CLOUDFLARE_S3_SECRET_ACCESS_KEY=
# R2 bucket for TTS / audio (e.g. smartsubs)
CLOUDFLARE_R2_BUCKET_NAME=

# Public R2 base URL only (R2.dev or custom domain; no trailing slash). Vite + Edge sync use this.
# Cloudflare → R2 → bucket → Settings → public URL. Not *.r2.cloudflarestorage.com.
R2_PUBLIC_BUCKET_URL=

# Optional legacy fallbacks if you omit R2_PUBLIC_BUCKET_URL (not recommended)
# CLOUDFLARE_R2_PUBLIC_URL=
# VITE_R2_PUBLIC_URL=

# Optional: eu | fedramp (default empty = standard R2 endpoint)
# CLOUDFLARE_R2_JURISDICTION=

# ─── Google Cloud TTS (Edge Function synthesize-thai-tts) ───
# Production: set Edge secret GOOGLE_TTS_API_KEY (Dashboard → Edge Functions → Secrets).
# Local dev: optional VITE_GOOGLE_TTS_API_KEY (sent to edge in JSON body; same exposure as any VITE_* secret).
# VITE_GOOGLE_TTS_API_KEY=your-google-cloud-api-key
# Optional Edge secret: GOOGLE_TTS_LANGUAGE_CODE=th-TH
